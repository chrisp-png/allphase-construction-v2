# Homepage — allow short browser cache + CDN edge cache with revalidation
# This prevents re-downloading everything on every visit while staying fresh
/
  Cache-Control: public, max-age=0, must-revalidate
  Netlify-CDN-Cache-Control: public, s-maxage=3600, stale-while-revalidate=86400

/index.html
  Cache-Control: public, max-age=0, must-revalidate
  Netlify-CDN-Cache-Control: public, s-maxage=3600, stale-while-revalidate=86400

# Hashed JS/CSS assets — immutable, cache for 1 year
# Vite puts content hashes in filenames so these are safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  Netlify-CDN-Cache-Control: public, s-maxage=31536000, immutable

# Images in root — cache for 30 days (no hash in name, may change)
/*.jpg
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400
/*.png
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400
/*.webp
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400
/*.svg
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

# Sitemap - ensure proper Content-Type
/sitemap.xml
  Content-Type: application/xml; charset=UTF-8
  X-Robots-Tag: index, follow

# Global headers for all paths
/*
  X-Robots-Tag: index, follow
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Specific headers for HTML pages (allow all crawlers)
/*.html
  X-Robots-Tag: index, follow

# API routes and dynamic content
/api/*
  X-Robots-Tag: noindex

# Ensure crawlers can access all public pages
/roofing-services/*
  X-Robots-Tag: index, follow

/locations/*
  X-Robots-Tag: index, follow

/blog/*
  X-Robots-Tag: index, follow
