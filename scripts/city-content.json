  "delray-beach": {
    "serviceAreaHtml": "<section class=\"mb-16\"><h2 class=\"text-3xl font-bold text-white mb-6\">Tile Roofing in Delray Beach – Local Factors</h2><div class=\"bg-zinc-900 border border-zinc-800 rounded-lg overflow-hidden\"><table class=\"w-full\"><thead><tr class=\"border-b border-zinc-800\"><th class=\"text-left px-6 py-4 text-white font-semibold\">Roofing Factor</th><th class=\"text-left px-6 py-4 text-white font-semibold\">Why It Matters in Delray Beach</th></tr></thead><tbody><tr class=\"border-b border-zinc-800\"><td class=\"px-6 py-4 text-zinc-300\">Tile roof popularity</td><td class=\"px-6 py-4 text-zinc-400\">Matches coastal and Mediterranean-style homes</td></tr><tr class=\"border-b border-zinc-800\"><td class=\"px-6 py-4 text-zinc-300\">Salt air exposure</td><td class=\"px-6 py-4 text-zinc-400\">Requires proper installation and underlayment</td></tr><tr class=\"border-b border-zinc-800\"><td class=\"px-6 py-4 text-zinc-300\">HOA requirements</td><td class=\"px-6 py-4 text-zinc-400\">Material and color consistency enforced</td></tr><tr class=\"border-b border-zinc-800\"><td class=\"px-6 py-4 text-zinc-300\">Storm resistance</td><td class=\"px-6 py-4 text-zinc-400\">Tile performs well in high-wind conditions</td></tr><tr class=\"border-b border-zinc-800 last:border-0\"><td class=\"px-6 py-4 text-zinc-300\">Aging underlayment</td><td class=\"px-6 py-4 text-zinc-400\">Common issue beneath existing tile roofs</td></tr></tbody></table></div></section><section class=\"mb-16\"><div class=\"bg-gradient-to-r from-red-600/10 to-red-500/5 border border-red-600/20 rounded-lg p-6\"><div class=\"flex items-start gap-4\"><svg class=\"w-6 h-6 text-red-500 flex-shrink-0 mt-1\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z\"></path></svg><div><h3 class=\"text-xl font-bold text-white mb-3\">Team Insight – Delray Beach Roofing</h3><p class=\"text-zinc-300 leading-relaxed mb-3\">\"Delray Beach has really changed over the years. The east side has transformed over the last 15 years, and the city has expanded further west with beautiful communities. It's always a pleasure working in Delray Beach.\"</p><p class=\"text-sm text-zinc-400\">— Charly, Field Supervisor, All Phase Construction</p></div></div></div></section>",
